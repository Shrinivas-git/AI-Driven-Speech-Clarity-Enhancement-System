# Speech Clarity Enhancement API - Environment Configuration

# Database Configuration
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/AI_Speech

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production-make-it-long-and-random
ALGORITHM=HS256

# JWT Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO

# File Upload Limits
MAX_FILE_SIZE_MB=50
MAX_AUDIO_DURATION_SECONDS=300

# Usage Limits
FREE_USAGE_LIMIT=10
PREMIUM_UNLIMITED=True

# Subscription Pricing (for display only - simulated payments)
MONTHLY_PREMIUM_PRICE=9.99
YEARLY_PREMIUM_PRICE=99.99

# Email Configuration (for future email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@speechclarity.com

# Redis Configuration (for future caching)
REDIS_URL=redis://localhost:6379/0

# Monitoring and Analytics
ENABLE_ANALYTICS=True
ANALYTICS_RETENTION_DAYS=90